generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENT
  COORDINATOR
  OPERATIONS
  FINANCE
}

enum EventStatus {
  DRAFT
  RECEIVED
  PROPOSAL_SENT
  PROPOSAL_ACCEPTED
  CONTRACT_SIGNED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  DEPOSIT_PAID
  FULLY_PAID
  OVERDUE
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CASH
  CHECK
}

model User {
  id                    String     @id @default(cuid())
  fullName              String
  email                 String     @unique
  password              String
  phone                 String?
  role                  UserRole   @default(CLIENT)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  client                Client?
  events                Event[]         @relation("UserEvents")
  bookings              Booking[]       @relation("UserBookings")
  clientEnquiries       Enquiry[]       @relation("UserEnquiries")
  coordinatorEnquiries  Enquiry[]       @relation("CoordinatorEnquiries")
  clientProposals       Proposal[]      @relation("UserProposals")
  coordinatorProposals  Proposal[]      @relation("CoordinatorProposals")
  clientContracts       Contract[]      @relation("UserContracts")
  coordinatorContracts  Contract[]      @relation("CoordinatorContracts")
  clientInvoices        Invoice[]       @relation("UserInvoices")
  clientPayments        Payment[]       @relation("UserPayments")
  assignedTimelines     Timeline[]      @relation("UserTimelines")
}

model Client {
  id          String   @id @default(cuid())
  userId      String   @unique
  company     String?
  preferences String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
}

model Enquiry {
  id           String   @id @default(cuid())
  clientId     String
  coordinatorId String?
  title        String
  description  String?
  briefText    String?
  status       String   @default("RECEIVED") // RECEIVED, PROPOSAL_SENT, ACCEPTED, REJECTED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client     User      @relation("UserEnquiries", fields: [clientId], references: [id])
  coordinator User?    @relation("CoordinatorEnquiries", fields: [coordinatorId], references: [id])
  proposals  Proposal[]
}

model Proposal {
  id           String   @id @default(cuid())
  enquiryId    String
  clientId     String
  coordinatorId String
  title        String
  content      String?
  totalAmount  Float
  status       String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  sentAt       DateTime?
  acceptedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enquiry    Enquiry   @relation(fields: [enquiryId], references: [id])
  client     User      @relation("UserProposals", fields: [clientId], references: [id])
  coordinator User      @relation("CoordinatorProposals", fields: [coordinatorId], references: [id])
  contracts  Contract[]
}

model Contract {
  id           String   @id @default(cuid())
  proposalId   String
  clientId     String
  coordinatorId String
  content      String
  status       String   @default("DRAFT") // DRAFT, SENT, SIGNED, CANCELLED
  sentAt       DateTime?
  signedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  proposal   Proposal  @relation(fields: [proposalId], references: [id])
  client     User      @relation("UserContracts", fields: [clientId], references: [id])
  coordinator User      @relation("CoordinatorContracts", fields: [coordinatorId], references: [id])
  events     Event[]
}

model Event {
  id          String      @id @default(cuid())
  contractId  String?
  title       String
  description String?
  type        String // Wedding, Corporate, Birthday, Conference, etc.
  status      EventStatus @default(DRAFT)
  clientId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contract   Contract? @relation(fields: [contractId], references: [id])
  client     User      @relation("UserEvents", fields: [clientId], references: [id])
  bookings   Booking[]
  timelines  Timeline[]
  invoices   Invoice[]
}

model Space {
  id              String    @id @default(cuid())
  name            String
  type            String
  capacity        Int
  hourlyRate      Float
  description     String?
  amenities       String? // JSON string
  isAvailable     Boolean   @default(true)
  requiresDeposit Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bookings Booking[]
}

model Equipment {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  quantity    Int      @default(1)
  rentalPrice Float
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookingEquipment BookingEquipment[]
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  category    String
  email       String
  phone       String
  address     String?
  description String?
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookingVendors BookingVendor[]
}

model Booking {
  id          String         @id @default(cuid())
  eventId     String
  spaceId     String
  userId      String         @default("")
  date        DateTime
  startTime   String
  endTime     String
  guestCount  Int
  status      BookingStatus  @default(PENDING)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  event            Event             @relation(fields: [eventId], references: [id])
  space            Space             @relation(fields: [spaceId], references: [id])
  user             User              @relation("UserBookings", fields: [userId], references: [id])
  bookingEquipment BookingEquipment[]
  bookingVendors   BookingVendor[]
}

model BookingEquipment {
  id          String   @id @default(cuid())
  bookingId   String
  equipmentId String
  quantity    Int      @default(1)

  booking   Booking   @relation(fields: [bookingId], references: [id])
  equipment Equipment @relation(fields: [equipmentId], references: [id])
}

model BookingVendor {
  id        String @id @default(cuid())
  bookingId String
  vendorId  String

  booking Booking @relation(fields: [bookingId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id])
}

model Timeline {
  id          String   @id @default(cuid())
  eventId     String
  title       String
  description String?
  startTime   String
  endTime     String
  assignedTo  String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id])
  assignee  User?    @relation("UserTimelines", fields: [assignedTo], references: [id])
}

model Invoice {
  id          String         @id @default(cuid())
  eventId     String
  clientId    String
  number      String
  amount      Float
  status      InvoiceStatus  @default(UNPAID)
  dueDate     DateTime
  pdfUrl      String?
  sentAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  event    Event     @relation(fields: [eventId], references: [id])
  client   User      @relation("UserInvoices", fields: [clientId], references: [id])
  payments Payment[]
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  clientId    String
  amount      Float
  method      PaymentMethod
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  client  User    @relation("UserPayments", fields: [clientId], references: [id])
}